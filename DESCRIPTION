Package: wiseapp
Title: Weather Impact Simulation and Evaluation for Adaptation Policy and Planning
Version: 0.0.1
Authors@R: c(
    person("Ben", "Brunckhorst", , "bbrunckhorst@worldbank.org", role = c("aut", "cre")),
